# VoiceNote AI Backend Configuration
# Copy this file to .env and update values

# App
APP_NAME=VoiceNote AI
APP_VERSION=0.1.0
DEBUG=true

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=524288000

# Faster Whisper (Local Transcription) - No API key needed
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# DeepSeek API Key (for AI analysis)
# Get your key from: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_ANALYSIS_MODEL=deepseek-chat

# HuggingFace Token (for pyannote speaker diarization)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your-huggingface-token

# AssemblyAI API Key (for speaker diarization)
# Get your key from: https://www.assemblyai.com
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# CORS (for development)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage Settings
STORAGE_PATH=
AUTO_CLEANUP_ENABLED=false
AUTO_CLEANUP_DAYS=30